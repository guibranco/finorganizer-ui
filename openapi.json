  "components": {
    "schemas": {
      "DashboardSummary": {
        "type": "object",
        "properties": {
          "netWorth": { "type": "number" },
          "cashBalance": { "type": "number" },
          "investedAmount": { "type": "number" },
          "thisMonthNet": { "type": "number" },
          "netWorthHistory": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "month": { "type": "string" },
                "amount": { "type": "number" }
              }
            }
          },
          "incomeVsExpenses": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "month": { "type": "string" },
                "income": { "type": "number" },
                "expenses": { "type": "number" }
              }
            }
          },
          "passiveIncomeTrend": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "month": { "type": "string" },
                "amount": { "type": "number" }
              }
            }
          },
          "trailing12MonthPassiveIncome": { "type": "number" },
          "allocationByAssetClass": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "number" }
              }
            }
          },
          "allocationByAccount": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "value": { "type": "number" }
              }
            }
          }
        },
        "required": ["netWorth", "cashBalance", "investedAmount", "thisMonthNet", "netWorthHistory", "incomeVsExpenses", "passiveIncomeTrend", "trailing12MonthPassiveIncome", "allocationByAssetClass", "allocationByAccount"]
      },
      "Account": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "currency": { "type": "string" },
          "balance": { "type": "number" },
          "isArchived": { "type": "boolean" }
        },
        "required": ["id", "name", "type", "currency", "balance", "isArchived"]
      },
      "CreateAccountDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "currency": { "type": "string" },
          "initialBalance": { "type": "number" }
        },
        "required": ["name", "type", "currency"]
      },
      "UpdateAccountDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "currency": { "type": "string" },
          "isArchived": { "type": "boolean" }
        },
        "required": ["name", "type", "currency"]
      },
      "BalanceHistoryItem": {
        "type": "object",
        "properties": {
          "date": { "type": "string" },
          "balance": { "type": "number" }
        },
        "required": ["date", "balance"]
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "accountId": { "type": "string" },
          "accountName": { "type": "string" },
          "date": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "type": { "type": "string" },
          "amount": { "type": "number" },
          "toAccountId": { "type": "string" },
          "toAccountName": { "type": "string" }
        },
        "required": ["id", "accountId", "date", "description", "category", "type", "amount"]
      },
      "CreateTransactionDto": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "date": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "type": { "type": "string" },
          "amount": { "type": "number" },
          "toAccountId": { "type": "string" }
        },
        "required": ["accountId", "date", "description", "category", "type", "amount"]
      },
      "UpdateTransactionDto": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "date": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "type": { "type": "string" },
          "amount": { "type": "number" },
          "toAccountId": { "type": "string" }
        },
        "required": ["accountId", "date", "description", "category", "type", "amount"]
      },
      "PaginatedTransactions": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Transaction" }
          },
          "totalCount": { "type": "integer" },
          "page": { "type": "integer" },
          "pageSize": { "type": "integer" },
          "totalPages": { "type": "integer" }
        },
        "required": ["items", "totalCount", "page", "pageSize", "totalPages"]
      },
      "CsvImportRequest": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "mappings": {
            "type": "object",
            "properties": {
              "date": { "type": "string" },
              "description": { "type": "string" },
              "category": { "type": "string" },
              "amount": { "type": "string" },
              "type": { "type": "string" }
            }
          },
          "rows": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "required": ["accountId", "mappings", "rows"]
      },
      "Category": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "color": { "type": "string" },
          "icon": { "type": "string" }
        },
        "required": ["id", "name", "color", "icon"]
      },
      "CategoryDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "color": { "type": "string" },
          "icon": { "type": "string" }
        },
        "required": ["name", "color", "icon"]
      },
      "AssetPosition": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ticker": { "type": "string" },
          "name": { "type": "string" },
          "assetClass": { "type": "string" },
          "quantity": { "type": "number" },
          "avgCost": { "type": "number" },
          "invested": { "type": "number" },
          "currentPrice": { "type": "number" },
          "marketValue": { "type": "number" },
          "unrealizedPl": { "type": "number" },
          "unrealizedPlPercent": { "type": "number" },
          "incomeReceived": { "type": "number" }
        },
        "required": ["id", "ticker", "assetClass", "quantity", "avgCost", "invested", "currentPrice", "marketValue", "unrealizedPl", "unrealizedPlPercent", "incomeReceived"]
      },
      "AssetDetail": {
        "type": "object",
        "properties": {
          "position": { "$ref": "#/components/schemas/AssetPosition" },
          "events": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/AssetEvent" }
          },
          "history": {
            "type": "array",
            "items": {
